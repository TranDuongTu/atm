{
  "agent": "opencode",
  "argv": [
    "opencode",
    "--auto",
    "--prompt",
    "Read the manager instructions in the file at /STORE/manager/FOO-RUNID.md and follow them exactly."
  ],
  "context_path": "/STORE/manager/FOO-RUNID.md",
  "env": {
    "ATM_ACTOR": "manager@opencode:unset",
    "ATM_BIN": "/ATM_BIN",
    "ATM_CONTEXT_FILE": "/STORE/manager/FOO-RUNID.md",
    "ATM_ONBOARD": "1",
    "ATM_PROJECT": "FOO",
    "ATM_ROLE": "manager",
    "ATM_RUN_ID": "FOO-RUNID"
  },
  "project": "FOO",
  "role": "manager",
  "run_id": "FOO-RUNID"
}
