== filter: []
  others
    open-chore
    open-bug
    done-chore
    multi-status
    type-only
    bare-tag
    mixed-bare
    unlabeled
== filter: [ATM:status:*]
  group ATM:status:blocked
    multi-status
  group ATM:status:done
    done-chore
  group ATM:status:open
    open-chore
    open-bug
    multi-status
    mixed-bare
  others
    type-only
    bare-tag
    unlabeled
